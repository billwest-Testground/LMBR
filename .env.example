ANTHROPIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=
# Outlook token encryption — AES-256-GCM key, 32 random bytes hex-encoded.
# Generate: openssl rand -hex 32
# Required for the Outlook integration; outlook_connections rows cannot
# be written or read without it.
OUTLOOK_TOKEN_ENCRYPTION_KEY=
# Outlook OAuth state HMAC secret — any high-entropy string. Also used
# as the signing secret for the CSRF-defense state param on the OAuth
# callback. Generate: openssl rand -hex 32
OUTLOOK_CLIENT_STATE_SECRET=
# Shared secret for the Graph subscription renewal cron target
# (POST /api/webhook/outlook/renew). Bearer-compared in constant time.
# Generate: openssl rand -hex 32
OUTLOOK_RENEWAL_SECRET=
# Lumber futures ticker (future premium feature)
# Add TWELVEDATA_API_KEY when customers request it
# Not included in V1
# Bearer secret for the daily Cash Index aggregation cron target
# (POST /api/market/aggregate). Same constant-time compare pattern
# as OUTLOOK_RENEWAL_SECRET. Generate: openssl rand -hex 32
# Add to apps/web/.env.local before scheduling the cron.
MARKET_AGGREGATE_SECRET=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ENV=development

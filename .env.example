ANTHROPIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=
# Outlook token encryption — AES-256-GCM key, 32 random bytes hex-encoded.
# Generate: openssl rand -hex 32
# Required for the Outlook integration; outlook_connections rows cannot
# be written or read without it.
OUTLOOK_TOKEN_ENCRYPTION_KEY=
# Outlook OAuth state HMAC secret — any high-entropy string. Also used
# as the signing secret for the CSRF-defense state param on the OAuth
# callback. Generate: openssl rand -hex 32
OUTLOOK_CLIENT_STATE_SECRET=
# Shared secret for the Graph subscription renewal cron target
# (POST /api/webhook/outlook/renew). Bearer-compared in constant time.
# Generate: openssl rand -hex 32
OUTLOOK_RENEWAL_SECRET=
# Market data — CME lumber futures (sentiment only).
# Cash market index is built from aggregated vendor bids (the
# Cash Index is the thing quotes price against; futures are
# directional context only). Using Twelve Data because the
# Barchart commercial tier starts at $500/month and the free
# Twelve Data tier (8 req/min, 800/day) comfortably covers the
# 15-minute refresh cadence.
# Sign up: twelvedata.com
TWELVEDATA_API_KEY=
# Bearer secret for the 15-minute CME futures refresh cron
# target (POST /api/market/futures/refresh). Same generate/
# compare pattern as OUTLOOK_RENEWAL_SECRET.
# Generate: openssl rand -hex 32
MARKET_REFRESH_SECRET=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ENV=development

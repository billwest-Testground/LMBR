{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@lmbr/types": [
        "../../packages/types/src"
      ],
      "@lmbr/lib": [
        "../../packages/lib/src"
      ],
      "@lmbr/config": [
        "../../packages/config/src"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "tailwind.config.ts"
  ]
}